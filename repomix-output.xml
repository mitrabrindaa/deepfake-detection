start_marker = '<div class="scan-cards">'
end_marker_after = "</div>\n      </div><!-- /container -->"

start_idx = content.find(start_marker)
# find the closing </div> of scan-cards
depth = 0
i = start_idx
while i < len(content):
    if content[i:i+4] == "<div":
