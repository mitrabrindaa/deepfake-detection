      <!-- Analyze -->
      <button id="analyze-btn">Analyze Image</button>

      <!-- Result -->
      <div id="result">
        <div class="result-label" id="result-label"></div>
        <div class="bar-row">
          <div class="bar-label"><span>Fake</span><span id="fake-pct">0%</span></div>
          <div class="bar-track"><div class="bar-fill fake" id="fake-bar" style="width:0%"></div></div>
        </div>
        <div class="bar-row">
          <div class="bar-label"><span>Real</span><span id="real-pct">0%</span></div>
          <div class="bar-track"><div class="bar-fill real" id="real-bar" style="width:0%"></div></div>
        </div>
      </div>

